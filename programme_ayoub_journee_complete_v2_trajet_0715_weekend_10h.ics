ACTION:DISPLAY
DESCRIPTION:Rappel - Musculation - Push + mollets
TRIGGER:-PT10M
END:VALARM
END:VEVENT
BEGIN:VEVENT
UID:25c87246-4427-4c2a-a863-8ac34d31ece2@copilot-ayoub-journee-complete-v2
