DTEND;TZID=Europe/Paris:20260518T201500
RRULE:FREQ=WEEKLY;BYDAY=TU;UNTIL=20260816T215959Z
DESCRIPTION:Objectif : dos\, arrière épaules\, biceps + avant-bras.\n1h45 : échauffement 10 min\; traction/tirage vertical 4x6-12\; rowing 4x8-12\; tirage horizontal 3x10-12\; face pull 4x12-20\; curl biceps 5 séries\; AVANT-BRAS : reverse curl 4x10-15 + wrist curl 3x15-20 + dead hang 3 séries max. Grip fort\, contrôle.
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:Rappel - Musculation - Pull + avant-bras
TRIGGER:-PT10M
END:VALARM
END:VEVENT
